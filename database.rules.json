{
  "rules": {
    ".read": false,
    ".write": false,

    "products":      { ".read": true, ".write": "auth != null" },
    "catalog":       { ".read": true, ".write": "auth != null" },
    "flavours":      { ".read": true, ".write": "auth != null" },
    "content":       { ".read": true, ".write": "auth != null" },
    "default-sizes": { ".read": true, ".write": "auth != null" },
    "categories":    { ".read": true, ".write": "auth != null" },
    "certificates":  { ".read": true, ".write": "auth != null" },
    "gallery-cat":   { ".read": true, ".write": "auth != null" },
    "shed-assortment": { ".read": true, ".write": "auth != null" },
    "site-status":   { ".read": true, ".write": "auth != null" },

    "reviews":       { ".read": true, ".write": true },

    "orders": {
      ".read": "auth != null",
      "$id": { ".write": "!data.exists() || auth != null" }
    },

    "order-status": {
      ".read": true,
      "$code": { ".write": "!data.exists() || auth != null" }
    }
  }
}
